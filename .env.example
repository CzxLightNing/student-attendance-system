# 学生考勤系统 - 环境变量配置示例
# 将此文件复制为 .env 并填入实际的配置值

# ==================== 运行环境配置 ====================
DJANGO_ENV=development

# ==================== 安全密钥 ====================
# Django 签名密钥，生产环境务必更换为随机字符串（长度 ≥ 50 字符）
SECRET_KEY=your-secret-key-here-change-in-production

# ==================== 站点配置 ====================
# 允许访问的域名/IP，多个用逗号分隔
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== 数据库配置 ====================
# SQLite 是默认开发数据库，无需任何环境变量即可使用
# 如需切换到 MySQL，取消下方注释并填入实际配置值：
# DATABASE_ENGINE=django.db.backends.mysql
# DATABASE_NAME=attendance_db
# DATABASE_USER=attendance_user
# DATABASE_PASSWORD=your-database-password-here
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
