# 敏感配置文件（包含密钥和数据库密码等）
.env

# SQLite 数据库文件
*.sqlite3

# Python 字节码缓存
__pycache__/
*.py[cod]
*.pyo

# 虚拟环境目录
venv/
env/
.venv/
.env/

# IDE 配置目录
.idea/
.vscode/
*.swp
*.swo

# 操作系统生成的文件
.DS_Store
Thumbs.db

# 静态文件收集目录
staticfiles/

# 媒体文件目录（临时导出文件）
media/

# 日志文件（保留目录结构 log/.gitkeep）
logs/*.log

# 分发/打包目录
dist/
build/
*.egg-info/
*.egg

# 单元测试覆盖率报告
htmlcov/
.coverage
.tox/

# 屏蔽.trae/
.trae/